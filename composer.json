{
    "name": "mailsage/mailsage",
    "description": "Parse, Understand, and Categorize Emails with One API. No SaaS. No accounts. 100% local.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "email",
        "parser",
        "eml",
        "mime",
        "spam",
        "invoice",
        "phishing",
        "categorization",
        "lead",
        "order"
    ],
    "homepage": "https://github.com/mailsage/mailsage",
    "authors": [
        {
            "name": "MailSage Contributors",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13",
        "friendsofphp/php-cs-fixer": "^3.40",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MailSage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailSage\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process",
        "rector-dry": "vendor/bin/rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}